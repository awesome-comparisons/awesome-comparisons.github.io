---
import { getCollection, render } from "astro:content"

import Layout from "@/layouts/main.astro"
import { AppShell } from "@/components/app-shell"
import DocPager from "@/components/DocPager.astro"
import { getContentTree, flattenContentTree } from "@/lib/content-tree"
import { getReadingStats } from "@/lib/reading-stats"

export async function getStaticPaths() {
  const entries = await getCollection("docs")

  return entries.map((entry) => ({
    params: { splat: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)
const tree = await getContentTree()
const { wordCount, readingTime } = getReadingStats(entry.body ?? "")

const flatDocs = flattenContentTree(tree)
const currentIndex = flatDocs.findIndex((doc) => doc.slug === entry.id)
const prev = currentIndex > 0 ? flatDocs[currentIndex - 1] : undefined
const next =
  currentIndex >= 0 && currentIndex < flatDocs.length - 1
    ? flatDocs[currentIndex + 1]
    : undefined

const summary = {
  title: entry.data.title,
  description: entry.data.description,
  headings,
  wordCount,
  readingTime,
}
---

<Layout title={entry.data.title}>
  <AppShell client:load tree={tree} activeSlug={entry.id} summary={summary}>
    <article class="typeset typeset-docs">
      <h1>{entry.data.title}</h1>
      {
        entry.data.description && (
          <p class="text-muted-foreground">{entry.data.description}</p>
        )
      }
      <Content />
    </article>
    <DocPager prev={prev} next={next} />
  </AppShell>
</Layout>

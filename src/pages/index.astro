---
import { getCollection } from "astro:content"

import Layout from "@/layouts/main.astro"
import { AppShell } from "@/components/app-shell"
import { getContentTree } from "@/lib/content-tree"

const tree = await getContentTree()
const entries = await getCollection("docs")
const introduction = entries.find((entry) => entry.id.endsWith("_introduction"))
---

<Layout>
  <AppShell client:load tree={tree}>
    <div class="typeset typeset-docs">
      <h1>Awesome Comparisons</h1>
      <p>
        Browse the sidebar to read language, framework, and tooling
        comparisons rendered straight from Markdown in
        <code>src/content/docs</code>.
      </p>
      {
        introduction && (
          <p>
            <a href={`/content/${introduction.id}`}>
              Start with the introduction &rarr;
            </a>
          </p>
        )
      }
    </div>
  </AppShell>
</Layout>
